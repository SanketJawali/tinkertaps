---
const {
	isAuthenticated,
	redirectToSignIn,
} = Astro.locals.auth();

if (!isAuthenticated) {
	return redirectToSignIn();
}

import AppNavbar from '../../components/app/AppNavbar.astro';
import Layout from '../../layouts/Layout.astro';
---

<Layout
	title="Home — Tinkertaps"
	description="Choose what you want to do with your files."
>
	<div class="min-h-screen bg-base-100 text-base-content">
		<AppNavbar />

		<main class="mx-auto max-w-6xl px-5 py-14 lg:px-8 lg:py-18">
			<section>
				<p
					class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary"
				>
					Your desk
				</p>

				<h1
					class="mt-4 text-4xl font-semibold tracking-[-0.04em] sm:text-5xl"
				>
					What do you need?
				</h1>

				<p class="mt-3 max-w-xl text-lg leading-8 text-base-content/55">
					Choose what you want to do. We'll ask for the file next.
				</p>
			</section>

			<section
				class="mt-12"
				aria-labelledby="actions-heading"
			>
				<h2 id="actions-heading" class="sr-only">
					File actions
				</h2>

				<div class="grid overflow-hidden rounded-box border border-base-300 md:grid-cols-3">
					<a
						href="/app/new?action=compress-image"
						class="group flex min-h-60 flex-col justify-between border-b border-base-300 p-7 transition-colors hover:bg-base-200/50 md:border-b-0 md:border-r"
					>
						<div>
							<p
								class="font-mono text-xs font-semibold uppercase tracking-[0.14em] text-primary"
							>
								Image
							</p>

							<h3
								class="mt-5 text-2xl font-semibold tracking-[-0.03em]"
							>
								Make it smaller
							</h3>

							<p class="mt-3 max-w-xs leading-7 text-base-content/55">
								Reduce an image's size while keeping it useful.
							</p>
						</div>

						<span
							class="mt-8 text-sm font-medium transition-transform group-hover:translate-x-1"
							aria-hidden="true"
						>
							Choose →
						</span>
					</a>

					<a
						href="/app/new?action=convert-image"
						class="group flex min-h-60 flex-col justify-between border-b border-base-300 p-7 transition-colors hover:bg-base-200/50 md:border-b-0 md:border-r"
					>
						<div>
							<p
								class="font-mono text-xs font-semibold uppercase tracking-[0.14em] text-primary"
							>
								Image
							</p>

							<h3
								class="mt-5 text-2xl font-semibold tracking-[-0.03em]"
							>
								Change the format
							</h3>

							<p class="mt-3 max-w-xs leading-7 text-base-content/55">
								Turn an image into the format you need.
							</p>
						</div>

						<span
							class="mt-8 text-sm font-medium transition-transform group-hover:translate-x-1"
							aria-hidden="true"
						>
							Choose →
						</span>
					</a>

					<a
						href="/app/new?action=extract-pdf-text"
						class="group flex min-h-60 flex-col justify-between p-7 transition-colors hover:bg-base-200/50"
					>
						<div>
							<p
								class="font-mono text-xs font-semibold uppercase tracking-[0.14em] text-primary"
							>
								PDF
							</p>

							<h3
								class="mt-5 text-2xl font-semibold tracking-[-0.03em]"
							>
								Pull out the text
							</h3>

							<p class="mt-3 max-w-xs leading-7 text-base-content/55">
								Get the written text from a PDF as a separate file.
							</p>
						</div>

						<span
							class="mt-8 text-sm font-medium transition-transform group-hover:translate-x-1"
							aria-hidden="true"
						>
							Choose →
						</span>
					</a>
				</div>
			</section>

			<section class="mt-18" aria-labelledby="recent-heading">
				<div class="flex items-end justify-between gap-4">
					<div>
						<p
							class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary"
						>
							Recent
						</p>

						<h2
							id="recent-heading"
							class="mt-3 text-2xl font-semibold tracking-[-0.035em]"
						>
							Your files
						</h2>
					</div>

					<a
						href="/app/files"
						class="text-sm font-medium underline decoration-base-300 underline-offset-4 transition-colors hover:decoration-base-content"
					>
						See all
					</a>
				</div>

				<div class="mt-6 overflow-hidden rounded-box border border-base-300">
					<div
						class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-5 border-b border-base-300 px-6 py-5 sm:grid-cols-[minmax(0,1fr)_180px_110px_auto]"
					>
						<div class="min-w-0">
							<p class="truncate font-medium">
								camera-export.png
							</p>

							<p class="mt-1 text-sm text-base-content/45">
								14.8 MB → 4.2 MB
							</p>
						</div>

						<p class="hidden text-sm text-base-content/55 sm:block">
							Made smaller
						</p>

						<span class="badge badge-success badge-soft">
							Ready
						</span>

						<a
							href="/app/files/file-demo-1"
							class="btn btn-ghost btn-sm hidden sm:inline-flex"
						>
							Open
						</a>
					</div>

					<div
						class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-5 border-b border-base-300 px-6 py-5 sm:grid-cols-[minmax(0,1fr)_180px_110px_auto]"
					>
						<div class="min-w-0">
							<p class="truncate font-medium">
								notes.pdf
							</p>

							<p class="mt-1 text-sm text-base-content/45">
								2.1 MB
							</p>
						</div>

						<p class="hidden text-sm text-base-content/55 sm:block">
							Pulling out text
						</p>

						<span class="badge badge-neutral badge-soft">
							Working
						</span>

						<a
							href="/app/files/file-demo-2"
							class="btn btn-ghost btn-sm hidden sm:inline-flex"
						>
							Open
						</a>
					</div>

					<div
						class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-5 px-6 py-5 sm:grid-cols-[minmax(0,1fr)_180px_110px_auto]"
					>
						<div class="min-w-0">
							<p class="truncate font-medium">
								cover.jpg
							</p>

							<p class="mt-1 text-sm text-base-content/45">
								8.7 MB
							</p>
						</div>

						<p class="hidden text-sm text-base-content/55 sm:block">
							Changed format
						</p>

						<span class="badge badge-success badge-soft">
							Ready
						</span>

						<a
							href="/app/files/file-demo-3"
							class="btn btn-ghost btn-sm hidden sm:inline-flex"
						>
							Open
						</a>
					</div>
				</div>
			</section>
		</main>
	</div>
</Layout>
