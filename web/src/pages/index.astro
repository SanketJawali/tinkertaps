---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Tinkertaps — Simple tools for everyday files"
	description="Compress images, change file formats, and work with everyday files."
>
	<div class="min-h-screen bg-base-100 text-base-content">
		<Navbar />

		<main>
			<section
				class="mx-auto grid max-w-6xl items-center gap-14 px-5 py-20 lg:grid-cols-[1fr_0.9fr] lg:px-8 lg:py-28"
			>
				<div class="max-w-2xl">
					<p
						class="mb-5 font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary"
					>
						Your file, your way
					</p>

					<h1
						class="max-w-xl text-5xl font-semibold leading-[0.98] tracking-[-0.045em] sm:text-6xl lg:text-7xl"
					>
						Drop it in.

						<span class="text-base-content/45">
							Choose what you need.
						</span>

						Take the result.
					</h1>

					<p
						class="mt-7 max-w-lg text-lg leading-8 text-base-content/65"
					>
						Compress an image, change a file's format, or pull
						text from a PDF. Choose a file and we'll take it
						from there.
					</p>

					<div class="mt-9 flex flex-wrap items-center gap-3">
						<a
							href="/new"
							class="btn btn-primary"
						>
							Choose a file
						</a>

						<a
							href="#how-it-works"
							class="btn btn-ghost"
						>
							How it works
						</a>
					</div>

					<p class="mt-5 text-sm text-base-content/45">
						You can close the page. Come back when it's ready.
					</p>
				</div>

				<div
					class="file-panel relative mx-auto w-full max-w-lg"
					aria-label="Example file status"
				>
					<div
						class="rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm"
					>
						<div class="mb-6 flex items-center justify-between">
							<div>
								<p
									class="font-mono text-[11px] uppercase tracking-[0.16em] text-base-content/45"
								>
									Your file
								</p>

								<p class="mt-1 font-medium">
									camera-export.png
								</p>
							</div>

							<span
								class="badge badge-success badge-soft gap-1.5"
							>
								<span
									class="size-1.5 rounded-full bg-success"
								></span>

								Ready
							</span>
						</div>

						<div class="file-steps">
							<div class="file-step">
								<span class="step-dot"></span>

								<div>
									<p class="font-medium">
										Uploaded
									</p>

									<p class="text-sm text-base-content/45">
										14.8 MB
									</p>
								</div>
							</div>

							<div class="file-step">
								<span class="step-dot"></span>

								<div>
									<p class="font-medium">
										Made smaller
									</p>

									<p class="text-sm text-base-content/45">
										Reduced by 71%
									</p>
								</div>
							</div>

							<div class="file-step">
								<span class="step-dot"></span>

								<div>
									<p class="font-medium">
										Ready
									</p>

									<p class="text-sm text-base-content/45">
										4.2 MB
									</p>
								</div>
							</div>
						</div>

						<div
							class="mt-5 flex items-center justify-between border-t border-base-300 pt-4"
						>
							<p class="text-sm text-base-content/45">
								Your file is ready
							</p>

							<button
								class="btn btn-primary btn-sm"
								type="button"
							>
								Download
							</button>
						</div>
					</div>
				</div>
			</section>

			<section
				id="how-it-works"
				class="border-y border-base-300 bg-base-200/50"
			>
				<div
					class="mx-auto max-w-6xl px-5 py-16 lg:px-8"
				>
					<div class="mb-10 max-w-xl">
						<p
							class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-primary"
						>
							How it works
						</p>

						<h2
							class="mt-3 text-3xl font-semibold tracking-[-0.035em] sm:text-4xl"
						>
							Three steps. That's it.
						</h2>
					</div>

					<div
						class="grid gap-px overflow-hidden rounded-2xl border border-base-300 bg-base-300 md:grid-cols-3"
					>
						<article class="bg-base-100 p-7">
							<p class="font-mono text-xs text-primary">
								01 / CHOOSE
							</p>

							<h3 class="mt-5 text-xl font-semibold">
								Pick a file
							</h3>

							<p
								class="mt-3 leading-7 text-base-content/60"
							>
								Choose the file you want to change.
							</p>
						</article>

						<article class="bg-base-100 p-7">
							<p class="font-mono text-xs text-primary">
								02 / CHANGE
							</p>

							<h3 class="mt-5 text-xl font-semibold">
								Choose what you need
							</h3>

							<p
								class="mt-3 leading-7 text-base-content/60"
							>
								Make it smaller, change its format, or
								pull out the text.
							</p>
						</article>

						<article class="bg-base-100 p-7">
							<p class="font-mono text-xs text-primary">
								03 / DONE
							</p>

							<h3 class="mt-5 text-xl font-semibold">
								Get your file
							</h3>

							<p
								class="mt-3 leading-7 text-base-content/60"
							>
								Come back when it's ready and download
								the result.
							</p>
						</article>
					</div>
				</div>
			</section>

			<section
				class="mx-auto max-w-6xl px-5 py-16 lg:px-8"
			>
				<div
					class="flex flex-col gap-8 rounded-2xl border border-base-300 bg-base-200/60 p-8 sm:flex-row sm:items-center sm:justify-between lg:p-10"
				>
					<div>
						<h2
							class="text-3xl font-semibold tracking-[-0.035em]"
						>
							Have a file waiting?
						</h2>

						<p class="mt-2 text-base-content/60">
							Choose it, tell us what you need, and we'll
							take it from there.
						</p>
					</div>

					<a
						href="/register"
						class="btn btn-primary shrink-0"
					>
						Choose a file
					</a>
				</div>
			</section>
		</main>

		<Footer />
	</div>
</Layout>

<style>
	.file-panel::before {
		content: '';
		position: absolute;
		inset: 18% -6% -8% 25%;
		z-index: -1;
		border-radius: 2rem;

		background: color-mix(
			in oklab,
			var(--color-primary) 7%,
			transparent
		);

		filter: blur(50px);
	}

	.file-steps {
		display: grid;
	}

	.file-step {
		position: relative;
		display: grid;
		grid-template-columns: 1.25rem 1fr;
		gap: 0.875rem;
		min-height: 5rem;
	}

	.file-step:not(:last-child)::after {
		content: '';
		position: absolute;
		top: 1.1rem;
		bottom: -0.1rem;
		left: 0.31rem;
		width: 1px;

		background: color-mix(
			in oklab,
			var(--color-primary) 35%,
			var(--color-base-300)
		);
	}

	.step-dot {
		position: relative;
		z-index: 1;
		margin-top: 0.35rem;
		display: block;
		width: 0.7rem;
		height: 0.7rem;

		border: 2px solid var(--color-base-100);
		border-radius: 999px;

		background: var(--color-primary);

		box-shadow:
			0 0 0 1px var(--color-primary);
	}

	@media (prefers-reduced-motion: no-preference) {
		.file-panel {
			animation: settle-in 500ms ease-out both;
		}

		@keyframes settle-in {
			from {
				opacity: 0;
				transform: translateY(8px);
			}

			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
	}
</style>
