---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Tinkertaps',
	description = 'Simple tools for everyday files.',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="tinkertaps">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />

		<meta
			name="description"
			content={description}
		/>

		<meta name="generator" content={Astro.generator} />

		<link
			rel="icon"
			type="image/svg+xml"
			href="/favicon.svg"
		/>

		<title>{title}</title>
	</head>

	<body>
		<slot />
	</body>
</html>
