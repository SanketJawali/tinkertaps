---
interface Props {
	currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;
---

<header class="border-b border-base-300">
	<nav
		class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 lg:px-8"
		aria-label="Primary navigation"
	>
		<a
			href="/"
			class="flex items-center gap-2.5 font-semibold tracking-tight"
		>
			<span
				class="grid size-8 place-items-center rounded-lg bg-neutral text-sm font-bold text-neutral-content"
			>
				T
			</span>

			<span>Tinkertaps</span>
		</a>

        <div class="flex items-center gap-2">
            {
                currentPath === '/login' ? (
                    <>
                        <span class="hidden text-sm text-base-content/50 sm:inline">
                            New here?
                        </span>

                        <a href="/register" class="btn btn-primary btn-sm">
                            Create account
                        </a>
                    </>
                ) : currentPath === '/register' ? (
                    <>
                        <span class="hidden text-sm text-base-content/50 sm:inline">
                            Already have an account?
                        </span>

                        <a href="/login" class="btn btn-ghost btn-sm">
                            Log in
                        </a>
                    </>
                ) : (
                    <>
                        <a href="/login" class="btn btn-ghost btn-sm">
                            Log in
                        </a>

                        <a href="/register" class="btn btn-primary btn-sm">
                            Get started
                        </a>
                    </>
                )
            }
        </div>
	</nav>
</header>
